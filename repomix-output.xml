            <a
              href={`${API}/api/stations/csv`}
              target="_blank"
              className="flex-1 font-mono text-[11px] border border-dex-border text-white px-3 py-2 rounded-sm text-center hover:border-dex-cyan transition"
            >
              DOWNLOAD
            </a>

          </div>
        </div>

        <div className="h-16" />

      </div>
    </aside>
  );
